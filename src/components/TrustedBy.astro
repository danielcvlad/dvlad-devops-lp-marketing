---
import OrangeLogo from '../assets/orange-logo.png';
import DanPortrait from '../assets/dan-portrait.jpg';
---

<section class="py-16 border-t" style="background-color: var(--color-surface-container-low); border-color: rgba(65, 71, 84, 0.1)">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-bold headline-font tracking-tighter uppercase mb-4">Where I've Worked</h2>
      <p class="max-w-xl mx-auto" style="color: var(--color-on-surface-variant)">
        Enterprise experience across consulting, tech, and telecom.
      </p>
    </div>

    <div class="flex flex-col md:flex-row items-center justify-center gap-8 md:gap-16 w-full max-w-lg md:max-w-none">
      <!-- Dan's Portrait -->
      <div class="flex flex-col items-center gap-3 w-full justify-start md:justify-center">
        <div class="w-24 h-24 rounded-full overflow-hidden border-2" style="border-color: var(--color-primary);">
          <img 
            src={DanPortrait.src} 
            alt="Daniel Vlad" 
            class="w-full h-full object-cover object-top"
            style="transform: translateY(-20%);"
          />
        </div>
        <div class="text-center">
          <div class="text-lg font-bold" style="color: var(--color-on-surface)">Daniel Vlad</div>
          <div class="text-xs" style="color: var(--color-on-surface-variant)">Your DevOps Consultant</div>
        </div>
      </div>

      <!-- Microsoft -->
      <div class="flex items-center gap-3 w-full justify-start md:justify-center opacity-80 hover:opacity-100 transition-opacity">
        <div class="w-10 h-10 flex items-center justify-center shrink-0">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" style="color: var(--color-primary)">
            <path d="M11.4 24H0V12.6h11.4V24zM24 24H12.6V12.6H24V24zM11.4 11.4H0V0h11.4v11.4zM24 11.4H12.6V0H24v11.4z"/>
          </svg>
        </div>
        <div class="text-left">
          <div class="text-lg font-bold" style="color: var(--color-primary)">Microsoft</div>
          <div class="text-xs" style="color: var(--color-on-surface-variant)">Support Escalation Engineer</div>
        </div>
      </div>

      <!-- Roland Berger -->
      <div class="flex items-center gap-3 w-full justify-start md:justify-center opacity-80 hover:opacity-100 transition-opacity">
        <div class="w-10 h-10 flex items-center justify-center shrink-0">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor" style="color: var(--color-secondary)">
            <path d="M12 2L2 7v10l10 5 10-5V7L12 2zm0 2.5L19 8l-7 3.5L5 8l7-3.5zM4 9.5l7 3.5v7l-7-3.5v-7zm16 0v7l-7 3.5v-7l7-3.5z"/>
          </svg>
        </div>
        <div class="text-left">
          <div class="text-lg font-bold" style="color: var(--color-secondary)">Roland Berger</div>
          <div class="text-xs" style="color: var(--color-on-surface-variant)">DevOps Engineer</div>
        </div>
      </div>

      <!-- Orange -->
      <div class="flex items-center gap-3 w-full justify-start md:justify-center opacity-80 hover:opacity-100 transition-opacity">
        <div class="w-10 h-10 flex items-center justify-center shrink-0">
          <img src={OrangeLogo.src} alt="Orange" width="32" height="32" class="object-contain" />
        </div>
        <div class="text-left">
          <div class="text-lg font-bold" style="color: var(--color-on-surface)">Orange</div>
          <div class="text-xs" style="color: var(--color-on-surface-variant)">Operational Specialist</div>
        </div>
      </div>
    </div>
  </div>
</section>
