---
import { resumeData } from '../data/resume';
---

<footer class="border-t-0" style="background-color: var(--color-background)">
  <div class="py-6" style="background-color: var(--color-surface-container-low)">
    <div class="flex flex-col md:flex-row justify-between items-center w-full px-8 gap-4 max-w-[1920px] mx-auto">
      <div class="font-bold headline-font tracking-tighter" style="color: var(--color-primary)">
        {resumeData.name.toUpperCase()} // DevOps Engineer
      </div>

      <div class="flex gap-8">
        <a class="font-mono text-[10px] uppercase tracking-widest transition-colors" style="color: var(--color-surface-container-highest)" href={resumeData.github} target="_blank">Github</a>
        <a class="font-mono text-[10px] uppercase tracking-widest transition-colors" style="color: var(--color-surface-container-highest)" href={resumeData.linkedin} target="_blank">LinkedIn</a>
        <a class="font-mono text-[10px] uppercase tracking-widest transition-colors" style="color: var(--color-surface-container-highest)" href="#about">Documentation</a>
        <a class="font-mono text-[10px] uppercase tracking-widest transition-colors" style="color: var(--color-surface-container-highest)" href="#contact">System Status</a>
      </div>

      <div class="font-mono text-[10px] uppercase tracking-widest" style="color: var(--color-outline-variant)">
        © 2024 {resumeData.name.toUpperCase()} // SYSTEM_ARCHITECT v1.0.42
      </div>
    </div>
  </div>
</footer>
