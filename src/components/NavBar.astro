---
const linkedinUrl = "https://linkedin.com/in/dancvlad";
const gitlabUrl = "https://gitlab.com/danielcvlad";
const resumeUrl = "/CV_Daniel_Vlad.pdf";
---

<header class="fixed top-0 left-0 right-0 z-50 border-b-0" style="background-color: var(--color-background)">
  <div class="flex justify-between items-center w-full px-4 md:px-6 py-3 max-w-[1920px] mx-auto relative">
    <!-- Mobile: hamburger + logo, Desktop: logo + nav + buttons -->
    <div class="flex items-center gap-4 w-full justify-between">
      <!-- Logo placeholder -->
      <div class="w-8 h-8 flex items-center justify-center">
        <span class="text-lg font-black" style="color: var(--color-primary)">{'>'}</span>
      </div>

      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-8">
        <a class="pb-1 headline-font text-sm tracking-widest uppercase" style="color: var(--color-primary); border-bottom: 1px solid var(--color-primary)" href="#about">About</a>
        <a class="headline-font text-sm tracking-widest uppercase transition-opacity hover:opacity-100" style="color: var(--color-secondary); opacity: 0.7" href="#experience">Experience</a>
        <a class="headline-font text-sm tracking-widest uppercase transition-opacity hover:opacity-100" style="color: var(--color-secondary); opacity: 0.7" href="#projects">Projects</a>
        <a class="headline-font text-sm tracking-widest uppercase transition-opacity hover:opacity-100" style="color: var(--color-secondary); opacity: 0.7" href="#contact">Contact</a>
      </nav>

      <!-- Buttons -->
      <div class="flex items-center gap-2 md:gap-4">
        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          onclick="toggleTheme()"
          class="flex items-center justify-center w-10 h-10 transition-opacity hover:opacity-70"
          style="color: var(--color-on-surface-variant)"
          title="Toggle dark/light mode"
          aria-label="Toggle theme"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3a9 9 0 1 0 9 9c0-.46-.04-.92-.1-1.36a5.389 5.389 0 0 1-4.4 2.26 5.403 5.403 0 0 1-3.14-9.8c-.44-.06-.9-.1-1.36-.1z"/></svg>
        </button>
        <a href={gitlabUrl} target="_blank" class="flex items-center justify-center w-10 h-10" title="GitLab">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--color-primary)"><path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 0 1-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 0 1 4.82 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.49h8.1l2.44-7.51A.42.42 0 0 1 18.6 2a.43.43 0 0 1 .58 0 .42.42 0 0 1 .11.18l2.44 7.51L23 13.45a.84.84 0 0 1-.35.94z"/></svg>
        </a>
        <a href={linkedinUrl} target="_blank" class="flex items-center justify-center w-10 h-10" title="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-secondary)"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={resumeUrl} download class="btn-secondary hidden sm:inline-flex items-center gap-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
          Resume
        </a>
        <a href="#contact" class="btn-primary">
          HIRE_ME
        </a>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 w-full h-[1px]" style="background: linear-gradient(to right, var(--color-primary), transparent, transparent)"></div>
  </div>
</header>
