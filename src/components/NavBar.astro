---
import { resumeData } from '../data/resume';
---

<header class="fixed top-0 left-0 right-0 z-50 border-b-0" style="background-color: var(--color-background)">
  <div class="flex justify-between items-center w-full px-6 py-4 max-w-[1920px] mx-auto relative">
    <a href="#about" class="text-xl font-black tracking-tighter headline-font" style="color: var(--color-primary)">
      dvlad
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a class="pb-1 headline-font text-sm tracking-widest uppercase" style="color: var(--color-primary); border-bottom: 1px solid var(--color-primary)" href="#about">About</a>
      <a class="headline-font text-sm tracking-widest uppercase transition-opacity hover:opacity-100" style="color: var(--color-secondary); opacity: 0.7" href="#experience">Experience</a>
      <a class="headline-font text-sm tracking-widest uppercase transition-opacity hover:opacity-100" style="color: var(--color-secondary); opacity: 0.7" href="#projects">Projects</a>
      <a class="headline-font text-sm tracking-widest uppercase transition-opacity hover:opacity-100" style="color: var(--color-secondary); opacity: 0.7" href="#contact">Contact</a>
    </nav>

    <div class="flex items-center gap-4">
      <div class="hidden sm:flex gap-4 mr-4">
        <a href="https://github.com/danielcvlad" target="_blank" class="material-symbols-outlined" style="color: var(--color-primary)" title="GitHub">terminal</a>
        <a href="https://linkedin.com/in/dancvlad" target="_blank" class="material-symbols-outlined" style="color: var(--color-secondary)" title="LinkedIn">cloud_done</a>
      </div>
      <a href="#contact" class="btn-primary">
        HIRE_ME
      </a>
    </div>

    <div class="absolute bottom-0 left-0 w-full h-[1px]" style="background: linear-gradient(to right, var(--color-primary), transparent, transparent)"></div>
  </div>
</header>
