---
import { resumeData } from '../data/resume';

// Microsoft Learn certification badge URLs
const certBadges: Record<string, { bg: string; label: string }> = {
  expert: {
    bg: "https://learn.microsoft.com/media/learn/certification/badges/microsoft-certified-expert-badge.svg",
    label: "Expert"
  },
  associate: {
    bg: "https://learn.microsoft.com/media/learn/certification/badges/microsoft-certified-associate-badge.svg",
    label: "Associate"
  },
  specialty: {
    bg: "https://learn.microsoft.com/media/learn/certification/badges/microsoft-certified-specialty-badge.svg",
    label: "Specialty"
  }
};
---

<section class="py-24 max-w-6xl mx-auto px-6 text-center">
  <h2 class="text-3xl font-bold headline-font tracking-tighter uppercase mb-16">Certification Wall</h2>

  <div class="max-w-3xl mx-auto border overflow-hidden" style="background-color: var(--color-surface-container-lowest); border-color: rgba(65, 71, 84, 0.2)">
    <!-- Terminal Header -->
    <div class="px-6 py-2 flex items-center justify-between" style="background-color: var(--color-surface-container-highest); border-bottom: 1px solid rgba(65, 71, 84, 0.2)">
      <span class="text-[10px] font-mono uppercase tracking-widest" style="color: var(--color-secondary); opacity: 0.7">
        Verified Credentials // Auth_Success
      </span>
      <div class="flex gap-1.5">
        <div class="w-2 h-2" style="background-color: var(--color-primary); opacity: 0.5"></div>
      </div>
    </div>

    <!-- Certifications List -->
    <div class="p-0 text-left">
      {resumeData.certifications.map((cert, index) => (
        <div
          class="flex items-center group cursor-pointer transition-colors"
          style={index === resumeData.certifications.length - 1 ? '' : 'border-bottom: 1px solid rgba(65, 71, 84, 0.1)'}
        >
          <div class="px-5 py-4 flex items-center justify-center" style="border-right: 1px solid rgba(65, 71, 84, 0.1)">
            <div class="w-12 h-12 flex items-center justify-center">
              <img
                src={certBadges[cert.level.toLowerCase() as keyof typeof certBadges].bg}
                alt={cert.level}
                class="w-full h-full object-contain"
                loading="lazy"
              />
            </div>
          </div>
          <div class="px-6 py-4 flex-grow flex items-center justify-between">
            <div>
              <div class={`text-sm font-bold headline-font mb-0.5 uppercase tracking-tight ${cert.color === 'primary' ? 'text-primary' : 'text-secondary'}`}>
                {cert.name}
              </div>
              <div class="text-[10px] font-mono uppercase" style="color: var(--color-outline-variant)">
                ID: {cert.id} // {cert.issuer}
              </div>
            </div>
            <div class="hidden sm:block text-[9px] font-mono uppercase tracking-tighter" style="color: var(--color-primary); opacity: 0.4">
              status: [VERIFIED_SECURE]
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
